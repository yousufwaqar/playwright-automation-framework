# Example environment configuration.
#
# Copy this file to `.env` and adjust values as needed. `.env` is gitignored;
# never commit real secrets. Every variable is optional — when unset the
# framework falls back to the active block in tests/test-data/environments.json.

# Which environment block to load from tests/test-data/environments.json
# (e.g. local | ci). An unknown value fails fast at startup.
TEST_ENV=local

# Application and API base URLs. Override the values from the environment block.
BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api/v1

# Bearer token the mock API expects on protected endpoints.
API_TOKEN=mock-jwt-token-12345

# Origin the mock app echoes in Access-Control-Allow-Origin (non-wildcard CORS).
ALLOWED_ORIGIN=http://localhost:3000

# Port the mock app listens on.
MOCK_PORT=3000

# Logger verbosity: DEBUG | STEP | INFO | WARN | ERROR (default INFO).
# Anything below the threshold is suppressed.
LOG_LEVEL=INFO
