{
  "name": "playwright-automation-framework",
  "version": "1.1.0",
  "description": "Enterprise-grade Playwright + TypeScript test automation framework with POM, parallel execution, and CI/CD integration",
  "author": "Yousuf Waqar <yousufwaqar7@gmail.com>",
  "license": "MIT",
  "scripts": {
    "test": "NODE_OPTIONS='--import tsx' npx playwright test --grep-invert @external",
    "test:headed": "NODE_OPTIONS='--import tsx' npx playwright test --headed --grep-invert @external",
    "test:chrome": "NODE_OPTIONS='--import tsx' npx playwright test --project=chromium --grep-invert @external",
    "test:firefox": "NODE_OPTIONS='--import tsx' npx playwright test --project=firefox --grep-invert @external",
    "test:webkit": "NODE_OPTIONS='--import tsx' npx playwright test --project=webkit --grep-invert @external",
    "test:api": "NODE_OPTIONS='--import tsx' npx playwright test tests/api/",
    "test:smoke": "NODE_OPTIONS='--import tsx' npx playwright test --grep @smoke --grep-invert @external",
    "test:regression": "NODE_OPTIONS='--import tsx' npx playwright test --grep @regression --grep-invert @external",
    "test:external": "NODE_OPTIONS='--import tsx' npx playwright test --grep @external",
    "test:saucedemo": "NODE_OPTIONS='--import tsx' npx playwright test --grep @saucedemo",
    "test:theinternet": "NODE_OPTIONS='--import tsx' npx playwright test --grep @theinternet",
    "test:api:external": "NODE_OPTIONS='--import tsx' npx playwright test tests/external/api/",
    "report": "npx playwright show-report",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf test-results/ playwright-report/"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^25.6.0",
    "dotenv": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "playwright",
    "typescript",
    "test-automation",
    "e2e-testing",
    "page-object-model",
    "ci-cd",
    "azure-devops",
    "quality-gates"
  ]
}
